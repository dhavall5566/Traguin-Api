# Split PostgreSQL — CMS (cms schema) and CRM (crm schema) can live on one or two databases.
# Only the API backend reads/writes the database. Frontends use CMS_API_URL / CRM_API_URL.
CMS_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/traguincms
CRM_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/traguincrm
# Fallback when CMS/CRM URLs are omitted (single unified database with both schemas)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE
JWT_SECRET_KEY=change-me-to-a-long-random-string
# Comma-separated browser origins allowed to call the API (include production domains)
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,https://traguin.in,https://www.traguin.in
TRAGUIN_DEFAULT_AGENCY_ID=
TRAGUIN_SYSTEM_USER_ID=
GROQ_API_KEY=
PEXELS_API_KEY=your-pexels-api-key
# WhatsMarketing — full apiToken from developer console (user_id|token)
WHATSAPP_API_URL=
WHATSAPP_API_BASE_URL=https://app.whatsmarketing.in
# Integer ID for your connected WhatsApp account (Traguin bot) — from developer console dropdown
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_LEAD_TEMPLATE=demo_new
# Optional separate template for non-lead CRM alerts; falls back to WHATSAPP_LEAD_TEMPLATE
WHATSAPP_CRM_TEMPLATE=
WHATSAPP_LEAD_TEMPLATE_LANGUAGE=en
WHATSAPP_NOTIFICATIONS_ENABLED=true
WHATSAPP_CRM_BASE_URL=http://localhost:3002
# Public URL for /uploads/media/* links returned by the API (production API domain)
API_PUBLIC_BASE_URL=https://api.traguin.in
